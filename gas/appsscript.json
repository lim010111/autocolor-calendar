{
  "timeZone": "Asia/Seoul",
  "exceptionLogging": "STACKDRIVER",
  "runtimeVersion": "V8",
  "oauthScopes": [
    "https://www.googleapis.com/auth/calendar",
    "https://www.googleapis.com/auth/script.external_request",
    "https://www.googleapis.com/auth/script.locale",
    "https://www.googleapis.com/auth/calendar.addons.execute",
    "https://www.googleapis.com/auth/calendar.addons.current.event.read",
    "https://www.googleapis.com/auth/calendar.addons.current.event.write",
    "https://www.googleapis.com/auth/userinfo.email"
  ],
  "urlFetchWhitelist": [
    "https://autocolor-dev.autocolor-lim.workers.dev/",
    "https://autocolor-prod.autocolor-lim.workers.dev/",
    "https://autocolorcal.app/"
  ],
  "addOns": {
    "common": {
      "name": "AutoColor",
      "logoUrl": "https://legal.autocolorcal.app/icon-128.png",
      "useLocaleFromApp": true,
      "openLinkUrlPrefixes": [
        "https://autocolor-dev.autocolor-lim.workers.dev",
        "https://autocolor-prod.autocolor-lim.workers.dev",
        "https://autocolorcal.app",
        "https://legal.autocolorcal.app",
        "https://accounts.google.com/o/oauth2/"
      ],
      "homepageTrigger": {
        "runFunction": "buildAddOn",
        "enabled": true
      }
    },
    "calendar": {
      "currentEventAccess": "READ_WRITE",
      "homepageTrigger": {
        "runFunction": "buildAddOn",
        "enabled": true
      },
      "eventOpenTrigger": {
        "runFunction": "onEventOpen"
      },
      "eventUpdateTrigger": {
        "runFunction": "onEventUpdate"
      }
    }
  },
  "webapp": {
    "executeAs": "USER_ACCESSING",
    "access": "ANYONE"
  }
}

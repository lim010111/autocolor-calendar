# Copy to .dev.vars for local `wrangler dev`. Never commit real values.
# Populated in Step 3+ of the backend setup plan.

# Runtime DB (Supabase Transaction Pooler, port 6543, ?sslmode=require)
DATABASE_URL=

# Migrations / DDL only (Supabase Direct, port 5432) — used by drizzle-kit locally
DIRECT_DATABASE_URL=

# Google OAuth Web Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GAS web app /exec URL for OAuth redirect
GAS_REDIRECT_URL=

# 32-byte base64 secrets (generated via `pnpm gen-secrets`)
TOKEN_ENCRYPTION_KEY=
SESSION_HMAC_KEY=
SESSION_PEPPER=

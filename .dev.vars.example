# Copy to .dev.vars for local `wrangler dev`. Never commit real values.
# Populated in Step 3+ of the backend setup plan.

# Runtime DB is routed through Cloudflare Hyperdrive (bound in wrangler.toml);
# DATABASE_URL is kept locally only for reference / fallback — not a Worker secret.
DATABASE_URL=

# Migrations / DDL only (Supabase Session Pooler, port 5432, IPv4) —
# drizzle-kit runs locally via dotenv; never injected into the Worker.
DIRECT_DATABASE_URL=

# Google OAuth Web Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GAS web app /exec URL for OAuth redirect
GAS_REDIRECT_URL=

# 32-byte base64 secrets (generated via `pnpm gen-secrets`)
TOKEN_ENCRYPTION_KEY=
SESSION_HMAC_KEY=
SESSION_PEPPER=

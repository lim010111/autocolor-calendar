# Copy to .dev.vars for local `wrangler dev`. Never commit real values.
# Populated in Step 3+ of the backend setup plan.

# Migrations / DDL only (Supabase Session Pooler, port 5432, IPv4) —
# drizzle-kit reads this locally via dotenv; it is never injected into the
# Worker runtime. Runtime DB access goes through the HYPERDRIVE binding
# declared in wrangler.toml, so DATABASE_URL is intentionally absent here.
DIRECT_DATABASE_URL=

# Google OAuth Web Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GAS web app /exec URL for OAuth redirect
GAS_REDIRECT_URL=

# 32-byte base64 secrets (generated via `pnpm gen-secrets`)
TOKEN_ENCRYPTION_KEY=
SESSION_HMAC_KEY=
SESSION_PEPPER=

# §5.3 LLM fallback (OpenAI). Leave blank to disable — rule-miss events will
# count silently as `no_match` (same semantics as a LLM failure). Not a
# required secret; `sync-secrets.ts` skips it when empty.
OPENAI_API_KEY=

# Per-user daily LLM call ceiling (default 200). Set in wrangler.toml
# [env.*.vars] if you want a non-default value; leave out entirely to use the
# default. Listed here only as documentation — the script does not inject it.
# LLM_DAILY_LIMIT=200
